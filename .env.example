# Copy this file to .env and fill values from the Canva.cn integration page.
CANVA_CLIENT_ID=
CANVA_CLIENT_SECRET=

# Must exactly match the redirect URL configured in Canva.
CANVA_REDIRECT_URI=http://127.0.0.1:3001/oauth/redirect
CANVA_PORT=3001

# Optional canvapie runtime overrides.
# CANVAPIE_HOME=~/.canvapie
# CANVAPIE_CONFIG=~/.canvapie/config.json
# CANVAPIE_TOKEN_PATH=~/.canvapie/tokens.json

# Defaults below are for Canva China. If the Authentication page shows different
# hosts, use those exact hosts instead.
CANVA_WEB_BASE_URL=https://www.canva.cn
CANVA_API_BASE_URL=https://api.canva.cn/rest/v1

# Add design:content:read when you need export.
CANVA_SCOPES=design:meta:read design:content:read folder:read asset:read profile:read
