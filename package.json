{
  "name": "canvapie",
  "version": "0.1.0",
  "description": "Agent-friendly Canva.cn Connect API CLI for design export and PPTX inspection.",
  "private": true,
  "license": "MIT",
  "type": "module",
  "keywords": [
    "canva",
    "canva-cn",
    "connect-api",
    "cli",
    "pptx",
    "agent"
  ],
  "bin": {
    "canvapie": "./bin/canvapie.mjs"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node server.mjs",
    "canvapie": "node ./bin/canvapie.mjs",
    "check": "node --check server.mjs && node --check bin/canvapie.mjs"
  }
}
